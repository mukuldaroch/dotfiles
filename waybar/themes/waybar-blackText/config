{
    /* -----------------------------------------------------
     * Waybar Position & Layer
     * ----------------------------------------------------- */

    // Draw bar above windows
    "layer": "top",

    // Negative margins pull the bar tighter to the screen edges
    "margin-top": -10,
    "margin-bottom": -10,

    // Horizontal spacing from screen edges
    "margin-left": 0,
    "margin-right": 0,

    // Space between modules
    "spacing": 0,


    /* -----------------------------------------------------
     * Module Configuration Files
     * ----------------------------------------------------- */

    // External module definitions (keeps this file clean)
    "include": [
        "~/.config/waybar/themes/waybar-black/modules.json"
    ],


    /* -----------------------------------------------------
     * Left Side Modules
     * ----------------------------------------------------- */

    "modules-left": [
        "hyprland/workspaces",
        "wlr/taskbar",
        "hyprland/window"
    ],


    /* -----------------------------------------------------
     * Right Side Modules
     * ----------------------------------------------------- */

    "modules-right": [
        "pulseaudio",
        "bluetooth",
        "backlight",
        "battery",
        "network",
        "clock",
        "custom/exit"
    ]
}
