{
  // Rofi Application Launcher
  "custom/appmenu": {
    // START APPS LABEL
    "format": " ",
    // END APPS LABEL
    "on-click": "sleep 0.2;pkill rofi || rofi -show drun -replace",
    "on-click-right": "~/.config/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Workspaces
  "hyprland/workspaces": {
    //"on-scroll-up": "hyprctl dispatch workspace r-1",
    //"on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 6
    }
  },

  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 20,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    //"ignore-list": ["Alacritty", "kitty"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },

  // Hyprland Window
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },
  //---------------------------------------------------------------------------

  // Empty
  "custom/empty": {
    "format": ""
  },

  //---------------------------------------------------------------------------

  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}%  {icon}пКФ {format_source}",
    "format-bluetooth-muted": "пЪ©  {icon}пКФ {format_source}",
    "format-muted": "пЪ©  {format_source}",
    //"format-source": "{volume}% пД∞",
    "format-source": "",
    "format-source-muted": "пД± ",
    "format-icons": {
      "headphone": "пА• ",
      "hands-free": "пЦР ",
      "headset": "пЦР ",
      "phone": "пВХ ",
      "portable": "пВХ ",
      "car": "пЖє ",
      "default": ["пА¶ ", "пА® ", "пА® "]
    },
    "on-click": "pavucontrol"
  },

  //  "format-disabled": "у∞В≤ Off",
  //  "format": "пКУ вЗµ Upload/Download",
  //  "format-disabled": "у∞В≤ вЗµ Off",
  //  "format-connected": "у∞В± Connected: {device_alias}",
  // "format-connected": "пКУ вђН ",
  // Bluetooth
  "bluetooth": {
    "format": "пКУ {status}",
    "format-connected": "пКФ",
    "format-off": "у∞В≤ Off",
    "format-disabled": "пКУ {status}",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": "у∞В≤ No Controller"
  },

  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "scroll-step": 1,
    "format-icons": [
      "оОН",
      "оПФ",
      "оПУ",
      "оПТ",
      "оПС",
      "оПР",
      "оПП",
      "оПО",
      "оПН",
      "оПМ",
      "оПЛ",
      "оПК",
      "оПЙ",
      "оПИ",
      "оОЫ"
    ]
  },

  // Battery
  "battery": {
    "states": {
      "good": 100,
      "warning": 90,
      "critical": 20
    },
    "format": "{icon} {capacity}%",
    "format-charging": "пЧІ  {capacity}%",
    "format-plugged": "пЗ¶  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-good": "{icon} {capacity}%", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["пЙД ", "пЙГ ", "пЙВ ", "пЙБ ", "пЙА "]
  },

  // Network
  "network": {
    "format": "{ifname}",
    //"format-wifi": "пЗЂ {essid} ({signalStrength}%)",
    "format-wifi": "пЗЂ  {signalStrength}%",
    "format-ethernet": "пЮЦ  {ifname}",
    "format-disconnected": "Disconnected вЪ†",
    "tooltip-format": "пЮЦ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "пЗЂ  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "пЮЦ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "~/.config/waybar/scripts/networkmanager.sh",
    "on-click-right": "~/.config/waybar/scripts/nm-applet.sh toggle"
  },

  // Power Menu
  "custom/exit": {
    "format": "пАС",
    "on-click": "~/.config/waybar/scripts/wlogout.sh",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },

  // Clock
  "clock": {
    "format": "{:%I:%M %p - %a}",
    "timezone": "",
    "tooltip": false
  }
}
